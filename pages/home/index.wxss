.notice-bar {
  display: flex;
  align-items: center;
  gap: 18rpx;
  height: 72rpx;
  margin-bottom: 20rpx;
  padding: 0 22rpx;
  border-radius: 18rpx;
  background: #ffffff;
  overflow: hidden;
}

.notice-label {
  flex: 0 0 auto;
  color: #176bff;
  font-size: 26rpx;
  font-weight: 700;
}

.notice-marquee {
  position: relative;
  flex: 1;
  min-width: 0;
  overflow: hidden;
  white-space: nowrap;
}

.notice-track {
  display: inline-block;
  min-width: 100%;
  padding-left: 100%;
  animation: notice-marquee 12s linear infinite;
}

.notice-text {
  color: #52627d;
  font-size: 24rpx;
}

@keyframes notice-marquee {
  0% {
    transform: translate3d(0, 0, 0);
  }
  100% {
    transform: translate3d(-100%, 0, 0);
  }
}

.video-swiper {
  height: 390rpx;
  margin-bottom: 24rpx;
}

.video-hero {
  position: relative;
  overflow: hidden;
  min-height: 390rpx;
  border-radius: 18rpx;
  padding: 28rpx;
  background: linear-gradient(145deg, #12315f 0%, #176bff 56%, #19a7ce 100%);
  color: #fff;
  box-sizing: border-box;
}

.video-cover,
.video-shade {
  position: absolute;
  top: 0;
  right: 0;
  bottom: 0;
  left: 0;
  width: 100%;
  height: 100%;
}

.video-shade {
  background: linear-gradient(180deg, rgba(12, 23, 42, 0.28) 0%, rgba(12, 23, 42, 0.82) 100%);
}

.video-top {
  position: relative;
  z-index: 1;
  display: flex;
  justify-content: space-between;
}

.video-time {
  color: rgba(255, 255, 255, 0.8);
  font-size: 24rpx;
}

.play {
  position: relative;
  z-index: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  width: 116rpx;
  height: 116rpx;
  margin: 80rpx auto 54rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.2);
  font-size: 44rpx;
}

.video-title,
.video-desc {
  position: relative;
  z-index: 1;
  display: block;
}

.video-title {
  font-size: 36rpx;
  font-weight: 800;
}

.video-desc {
  margin-top: 10rpx;
  color: rgba(255, 255, 255, 0.84);
  font-size: 24rpx;
}

.promo-card {
  overflow: hidden;
  padding-top: 0;
  border-left: 8rpx solid #176bff;
}

.promo-image {
  display: block;
  width: calc(100% + 48rpx);
  height: 180rpx;
  margin: 0 -24rpx 24rpx;
}

.promo-actions {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
  margin-top: 24rpx;
}

.promo-file {
  flex: 1;
  min-width: 0;
  color: #7b8798;
  font-size: 22rpx;
  line-height: 1.4;
}

.promo-cache-btn {
  flex: 0 0 auto;
  min-width: 160rpx;
  padding: 14rpx 18rpx;
  border-radius: 12rpx;
  background: #eef5ff;
  color: #176bff;
  font-size: 24rpx;
  font-weight: 700;
  text-align: center;
}
