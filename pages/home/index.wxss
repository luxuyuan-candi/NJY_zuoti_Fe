.page-home {
  position: relative;
  padding-top: 40rpx;
  padding-bottom: 44rpx;
}

.page-ornament {
  position: absolute;
  pointer-events: none;
  opacity: 0.2;
}

.page-ornament-left {
  top: 1240rpx;
  left: 24rpx;
  width: 120rpx;
  height: 180rpx;
  background:
    radial-gradient(circle at 30% 18%, rgba(117, 143, 105, 0.55) 0 8rpx, transparent 10rpx),
    linear-gradient(120deg, transparent 38%, rgba(117, 143, 105, 0.55) 39%, rgba(117, 143, 105, 0.55) 42%, transparent 43%),
    linear-gradient(135deg, transparent 44%, rgba(117, 143, 105, 0.45) 45%, rgba(117, 143, 105, 0.45) 48%, transparent 49%);
}

.page-ornament-right {
  right: 20rpx;
  bottom: 88rpx;
  width: 160rpx;
  height: 100rpx;
  background:
    radial-gradient(circle at 20% 80%, rgba(188, 173, 145, 0.42) 0 26rpx, transparent 28rpx),
    radial-gradient(circle at 45% 66%, rgba(188, 173, 145, 0.35) 0 20rpx, transparent 22rpx),
    radial-gradient(circle at 72% 54%, rgba(188, 173, 145, 0.28) 0 18rpx, transparent 20rpx);
}

.brand-block {
  margin-bottom: 26rpx;
  padding: 6rpx 4rpx;
}

.brand-title {
  display: block;
  color: #264c36;
  font-size: 66rpx;
  font-weight: 700;
  line-height: 1.08;
  letter-spacing: 2rpx;
}

.brand-subtitle {
  display: block;
  margin-top: 18rpx;
  color: #6e685e;
  font-size: 28rpx;
  letter-spacing: 10rpx;
}

.notice-panel {
  display: flex;
  align-items: center;
  gap: 18rpx;
  min-height: 108rpx;
  margin-bottom: 28rpx;
  padding: 0 26rpx;
  border: 1rpx solid rgba(212, 196, 171, 0.5);
  border-radius: 30rpx;
  background: rgba(255, 252, 247, 0.94);
  box-shadow: 0 16rpx 34rpx rgba(86, 66, 35, 0.08);
}

.notice-icon-shell {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 54rpx;
  height: 54rpx;
  border-radius: 999rpx;
  background: rgba(37, 78, 55, 0.08);
}

.notice-icon {
  width: 30rpx;
  height: 30rpx;
}

.notice-main {
  flex: 1;
  min-width: 0;
}

.notice-text {
  display: block;
  color: #384134;
  font-size: 26rpx;
  line-height: 1.45;
}

.notice-action {
  display: flex;
  align-items: center;
  gap: 12rpx;
  color: #b38547;
  font-size: 24rpx;
  white-space: nowrap;
}

.notice-action-text {
  font-weight: 600;
}

.notice-action-arrow {
  font-size: 28rpx;
  line-height: 1;
}

.video-swiper {
  height: 454rpx;
  margin-bottom: 24rpx;
}

.video-hero {
  position: relative;
  overflow: hidden;
  min-height: 454rpx;
  padding: 22rpx 24rpx;
  border-radius: 32rpx;
  box-shadow: 0 26rpx 52rpx rgba(41, 27, 15, 0.18);
  color: #fffdf9;
  box-sizing: border-box;
}

.video-cover,
.video-shade {
  position: absolute;
  inset: 0;
  width: 100%;
  height: 100%;
}

.video-shade {
  background:
    linear-gradient(180deg, rgba(18, 33, 25, 0.28) 0%, rgba(18, 33, 25, 0.52) 58%, rgba(13, 24, 17, 0.82) 100%);
}

.video-top,
.video-copy,
.play-shell,
.video-progress-row {
  position: relative;
  z-index: 1;
}

.video-badge {
  display: inline-flex;
  align-items: center;
  height: 58rpx;
  padding: 0 24rpx;
  border-radius: 0 0 24rpx 0;
  background: rgba(29, 77, 54, 0.92);
  color: #fff8eb;
  font-size: 26rpx;
}

.video-copy {
  margin-top: 34rpx;
}

.video-title {
  display: block;
  max-width: 520rpx;
  font-size: 34rpx;
  font-weight: 700;
  line-height: 1.24;
}

.video-subtitle {
  display: block;
  margin-top: 14rpx;
  font-size: 24rpx;
  line-height: 1.5;
  color: rgba(255, 249, 238, 0.92);
}

.video-teacher {
  display: inline-flex;
  align-items: center;
  height: 52rpx;
  margin-top: 18rpx;
  padding: 0 22rpx;
  border: 1rpx solid rgba(255, 251, 245, 0.58);
  border-radius: 999rpx;
  color: #fffaf0;
  font-size: 22rpx;
}

.play-shell {
  display: flex;
  justify-content: center;
  margin-top: 26rpx;
}

.play-button {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 92rpx;
  height: 92rpx;
  border-radius: 999rpx;
  background: rgba(17, 63, 43, 0.88);
  box-shadow: 0 18rpx 36rpx rgba(0, 0, 0, 0.2);
}

.play-icon {
  width: 38rpx;
  height: 38rpx;
}

.video-progress-row {
  display: flex;
  align-items: center;
  gap: 18rpx;
  margin-top: 38rpx;
}

.video-progress-text {
  color: rgba(255, 249, 237, 0.92);
  font-size: 24rpx;
}

.video-progress {
  flex: 1;
  height: 12rpx;
  overflow: hidden;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.18);
}

.video-progress-fill {
  width: 56%;
  height: 100%;
  border-radius: 999rpx;
  background: linear-gradient(90deg, #d7b56d 0%, #b38a45 100%);
}

.section-head-home {
  margin-bottom: 24rpx;
}

.section-title-wrap {
  display: flex;
  align-items: center;
  gap: 14rpx;
}

.section-title-icon {
  width: 34rpx;
  height: 34rpx;
}

.promo-grid {
  display: grid;
  grid-template-columns: repeat(4, minmax(0, 1fr));
  gap: 14rpx;
}

.promo-card {
  min-height: 244rpx;
  padding: 18rpx 12rpx 20rpx;
  border-radius: 26rpx;
  text-align: center;
}

.promo-icon-shell {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 78rpx;
  height: 78rpx;
  margin: 0 auto 16rpx;
  border-radius: 20rpx;
  background: linear-gradient(180deg, rgba(255, 253, 248, 0.96) 0%, rgba(241, 232, 217, 0.96) 100%);
  box-shadow: inset 0 0 0 1rpx rgba(196, 163, 103, 0.18);
}

.promo-icon {
  width: 50rpx;
  height: 50rpx;
}

.promo-title {
  display: block;
  color: #22382b;
  font-size: 22rpx;
  font-weight: 700;
  line-height: 1.35;
}

.promo-desc {
  display: block;
  margin-top: 10rpx;
  color: #6d6458;
  font-size: 18rpx;
  line-height: 1.45;
}

.promo-summary {
  display: block;
  margin-top: 16rpx;
  color: #b28240;
  font-size: 18rpx;
  font-weight: 600;
}

.promo-actions {
  margin-top: 10rpx;
}

.promo-cache-btn {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-width: 104rpx;
  min-height: 38rpx;
  padding: 0 14rpx;
  border-radius: 999rpx;
  background: rgba(247, 241, 230, 0.92);
  color: #ad8040;
  font-size: 16rpx;
}

.shortcut-card {
  display: grid;
  grid-template-columns: repeat(4, minmax(0, 1fr));
  gap: 0;
  margin-top: 28rpx;
  padding: 18rpx 0;
  border: 1rpx solid rgba(212, 196, 171, 0.46);
  border-radius: 32rpx;
  background: rgba(255, 252, 247, 0.95);
  box-shadow: 0 18rpx 38rpx rgba(88, 67, 35, 0.08);
}

.shortcut-item {
  position: relative;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 16rpx;
  padding: 18rpx 10rpx;
}

.shortcut-item::after {
  content: '';
  position: absolute;
  top: 16rpx;
  right: 0;
  width: 1rpx;
  height: 96rpx;
  background: rgba(220, 210, 192, 0.9);
}

.shortcut-item:last-child::after {
  display: none;
}

.shortcut-icon {
  width: 60rpx;
  height: 60rpx;
}

.shortcut-label {
  color: #253a2c;
  font-size: 24rpx;
}

.quote-card {
  position: relative;
  overflow: hidden;
  margin-top: 28rpx;
  padding: 36rpx 34rpx 34rpx;
  border: 1rpx solid rgba(219, 206, 185, 0.5);
  border-radius: 30rpx;
  background: rgba(248, 242, 230, 0.6);
  box-shadow: inset 0 0 0 1rpx rgba(255, 255, 255, 0.25);
}

.quote-bamboo {
  position: absolute;
  left: 20rpx;
  bottom: 10rpx;
  width: 110rpx;
  height: 130rpx;
  opacity: 0.22;
  background:
    linear-gradient(160deg, transparent 28%, rgba(115, 141, 104, 0.8) 29%, rgba(115, 141, 104, 0.8) 31%, transparent 32%),
    linear-gradient(130deg, transparent 46%, rgba(115, 141, 104, 0.72) 47%, rgba(115, 141, 104, 0.72) 49%, transparent 50%),
    linear-gradient(90deg, transparent 50%, rgba(115, 141, 104, 0.48) 51%, rgba(115, 141, 104, 0.48) 53%, transparent 54%);
}

.quote-mountain {
  position: absolute;
  right: 20rpx;
  bottom: 14rpx;
  width: 138rpx;
  height: 74rpx;
  opacity: 0.16;
  background:
    radial-gradient(circle at 20% 80%, rgba(175, 165, 144, 0.75) 0 24rpx, transparent 26rpx),
    radial-gradient(circle at 54% 72%, rgba(175, 165, 144, 0.6) 0 18rpx, transparent 20rpx),
    radial-gradient(circle at 78% 66%, rgba(175, 165, 144, 0.5) 0 14rpx, transparent 16rpx);
}

.quote-text,
.quote-author {
  position: relative;
  z-index: 1;
  display: block;
  text-align: center;
  color: #5c5446;
}

.quote-text {
  font-size: 28rpx;
  line-height: 1.8;
}

.quote-author {
  margin-top: 8rpx;
  font-size: 24rpx;
}
