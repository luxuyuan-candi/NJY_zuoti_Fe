.video-hero {
  position: relative;
  overflow: hidden;
  min-height: 390rpx;
  border-radius: 18rpx;
  padding: 28rpx;
  background: linear-gradient(145deg, #12315f 0%, #176bff 56%, #19a7ce 100%);
  color: #fff;
  box-sizing: border-box;
}

.video-cover,
.video-shade {
  position: absolute;
  top: 0;
  right: 0;
  bottom: 0;
  left: 0;
  width: 100%;
  height: 100%;
}

.video-shade {
  background: linear-gradient(180deg, rgba(12, 23, 42, 0.28) 0%, rgba(12, 23, 42, 0.82) 100%);
}

.video-top {
  position: relative;
  z-index: 1;
  display: flex;
  justify-content: space-between;
}

.video-time {
  color: rgba(255, 255, 255, 0.8);
  font-size: 24rpx;
}

.play {
  position: relative;
  z-index: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  width: 116rpx;
  height: 116rpx;
  margin: 80rpx auto 54rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.2);
  font-size: 44rpx;
}

.video-title,
.video-desc {
  position: relative;
  z-index: 1;
  display: block;
}

.video-title {
  font-size: 36rpx;
  font-weight: 800;
}

.video-desc {
  margin-top: 10rpx;
  color: rgba(255, 255, 255, 0.84);
  font-size: 24rpx;
}

.promo-card {
  overflow: hidden;
  padding-top: 0;
  border-left: 8rpx solid #176bff;
}

.promo-image {
  display: block;
  width: calc(100% + 48rpx);
  height: 180rpx;
  margin: 0 -24rpx 24rpx;
}
