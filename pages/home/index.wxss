.video-hero {
  min-height: 390rpx;
  border-radius: 18rpx;
  padding: 28rpx;
  background: linear-gradient(145deg, #12315f 0%, #176bff 56%, #19a7ce 100%);
  color: #fff;
  box-sizing: border-box;
}

.video-top {
  display: flex;
  justify-content: space-between;
}

.video-time {
  color: rgba(255, 255, 255, 0.8);
  font-size: 24rpx;
}

.play {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 116rpx;
  height: 116rpx;
  margin: 80rpx auto 54rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.2);
  font-size: 44rpx;
}

.video-title,
.video-desc {
  display: block;
}

.video-title {
  font-size: 36rpx;
  font-weight: 800;
}

.video-desc {
  margin-top: 10rpx;
  color: rgba(255, 255, 255, 0.84);
  font-size: 24rpx;
}

.promo-card {
  border-left: 8rpx solid #176bff;
}
