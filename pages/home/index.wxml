<view class="page">
  <view class="video-hero" bindtap="goVideo">
    <view class="video-top">
      <text class="tag">教学视频</text>
      <text class="video-time">08:32</text>
    </view>
    <view class="play">▶</view>
    <text class="video-title">南检院学习导览</text>
    <text class="video-desc">了解题库、考试、错题和离线缓存的使用方式</text>
  </view>

  <view class="section">
    <view class="section-head">
      <text class="section-title">学习推广</text>
      <text class="section-link" bindtap="goNotice">公告</text>
    </view>
    <view class="list">
      <view class="card promo-card" wx:for="{{promotions}}" wx:key="id" data-id="{{item.id}}" bindtap="goPromotion">
        <view class="row between">
          <text class="title">{{item.title}}</text>
          <text class="tag gray">{{item.tag}}</text>
        </view>
        <text class="desc">{{item.desc}}</text>
      </view>
    </view>
  </view>
</view>
