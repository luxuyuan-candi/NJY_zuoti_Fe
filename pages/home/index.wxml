<view class="page page-home">
  <view class="brand-block">
    <text class="brand-title">学以致考</text>
    <text class="brand-subtitle">专注考试 · 高效成长</text>
  </view>

  <view class="notice-bar" bindtap="goNotice">
    <text class="notice-label">公告</text>
    <view class="notice-marquee">
      <view class="notice-track">
        <text class="notice-text">{{notice.marqueeText || notice.title}}</text>
      </view>
    </view>
  </view>

  <swiper class="video-swiper" indicator-dots autoplay circular interval="5000" duration="500">
    <swiper-item wx:for="{{videos}}" wx:key="id">
      <view class="video-hero" data-id="{{item.id}}" bindtap="goVideo">
        <image class="video-cover" src="{{item.coverUrl}}" mode="aspectFill"></image>
        <view class="video-shade"></view>
        <view class="video-top">
          <text class="tag">精选课程</text>
          <text class="video-time">{{item.duration}}</text>
        </view>
        <view class="play">▶</view>
        <text class="video-title">{{item.title}}</text>
        <text class="video-desc">{{item.desc}}</text>
      </view>
    </swiper-item>
  </swiper>

  <view class="section">
    <view class="section-head">
      <text class="section-title">学习资料</text>
      <text class="section-link">{{promotions.length}} 项</text>
    </view>
    <view class="promo-grid">
      <view class="card promo-card" wx:for="{{promotions}}" wx:key="id" data-id="{{item.id}}" bindtap="goPromotion">
        <view class="promo-icon-shell">
          <image class="promo-icon" src="{{item.iconUrl}}" mode="aspectFit"></image>
        </view>
        <text class="promo-title">{{item.title}}</text>
        <text class="promo-desc">{{item.desc}}</text>
        <view class="promo-meta row between">
          <text class="tag gray">{{item.tag}}</text>
          <text class="promo-file">{{item.fileName}}</text>
        </view>
        <view class="promo-actions">
          <view class="promo-cache-btn" data-id="{{item.id}}" catchtap="cachePromotion">
            <text wx:if="{{cacheProgressMap[item.id] >= 0 && cacheProgressMap[item.id] <= 100}}">{{cacheProgressMap[item.id]}}%</text>
            <text wx:elif="{{cacheMap[item.id]}}">本地打开</text>
            <text wx:else>缓存到本地</text>
          </view>
        </view>
      </view>
    </view>
  </view>
</view>
