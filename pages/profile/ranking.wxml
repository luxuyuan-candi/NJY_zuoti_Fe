<view class="page">
  <view class="hero">
    <text class="hero-title">当前 {{current.currentScore || 0}} 分</text>
    <text class="hero-subtitle">总榜 {{current.total || '未上榜'}}，周榜 {{current.weekly || '未上榜'}}。</text>
  </view>

  <view class="section grid-3">
    <view class="card metric">
      <text class="metric-value">{{current.total || '--'}}</text>
      <text class="metric-label">总榜排名</text>
    </view>
    <view class="card metric">
      <text class="metric-value">{{current.weekly || '--'}}</text>
      <text class="metric-label">周榜排名</text>
    </view>
    <view class="card metric">
      <text class="metric-value">{{current.currentScore || 0}}</text>
      <text class="metric-label">当前积分</text>
    </view>
  </view>

  <view class="section tabs">
    <view
      wx:for="{{tabs}}"
      wx:key="key"
      class="tab {{activeTab === item.key ? 'active' : ''}}"
      data-tab="{{item.key}}"
      bindtap="switchTab"
    >
      {{item.label}}
    </view>
  </view>

  <view class="section list">
    <view class="card row between" wx:for="{{ranks}}" wx:key="rank">
      <view class="row rank-user">
        <text class="rank">#{{item.rank}}</text>
        <view class="avatar small-avatar">
          <image wx:if="{{item.avatarUrl}}" class="avatar-image" src="{{item.avatarUrl}}" mode="aspectFill"></image>
        </view>
        <view class="rank-meta">
          <view class="row" style="gap: 10rpx;">
            <text class="title">{{item.name}}</text>
            <text wx:if="{{item.isCurrentUser}}" class="tag">我</text>
          </view>
          <text class="desc">做题 {{item.answeredCount}} 题</text>
        </view>
      </view>
      <text class="metric-value rank-score">{{item.accuracy}}%</text>
    </view>
    <view class="card" wx:if="{{loadingRanks}}">
      <text class="desc">正在加载榜单...</text>
    </view>
    <view class="card" wx:elif="{{!ranks.length}}">
      <text class="title">{{activeTab === 'weekly' ? '周榜暂无符合条件的用户' : '总榜暂无符合条件的用户'}}</text>
      <text class="desc">达到 100 题后会按正确率进入榜单。</text>
    </view>
  </view>
</view>
