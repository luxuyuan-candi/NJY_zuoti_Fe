<view class="page">
  <view class="card profile-card">
    <view class="avatar">南</view>
    <view style="flex: 1;">
      <text class="title">{{loggedIn ? (nickname || '学习用户') : '未登录'}}</text>
      <text class="desc">{{loggedIn ? '已授权访问题库' : '登录后查看奖牌、排名和学习资产'}}</text>
    </view>
    <view class="btn secondary login-btn" bindtap="goLogin">{{loggedIn ? '资料' : '登录'}}</view>
  </view>

  <view class="section">
    <view class="section-head">
      <text class="section-title">奖牌</text>
      <text class="section-link" bindtap="goMedal">全部</text>
    </view>
    <view class="grid-3">
      <view class="card medal" wx:for="{{medals}}" wx:key="*this">🏅<text>{{item}}</text></view>
    </view>
  </view>

  <view class="section">
    <view class="section-head">
      <text class="section-title">排名</text>
      <text class="section-link" bindtap="goRanking">详情</text>
    </view>
    <view class="grid-3">
      <view class="card metric" wx:for="{{ranking}}" wx:key="label">
        <text class="metric-value">{{item.value}}</text>
        <text class="metric-label">{{item.label}}</text>
      </view>
    </view>
  </view>

  <view class="section">
    <view class="section-head"><text class="section-title">工具区</text></view>
    <view class="list">
      <view class="card row between" wx:for="{{tools}}" wx:key="name" data-url="{{item.url}}" bindtap="goTool">
        <text class="title">{{item.name}}</text>
        <text class="muted">›</text>
      </view>
    </view>
  </view>
</view>
