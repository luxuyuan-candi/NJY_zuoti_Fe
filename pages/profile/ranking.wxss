.tabs {
  display: flex;
  gap: 16rpx;
}

.tab {
  flex: 1;
  height: 76rpx;
  border-radius: 20rpx;
  background: #ffffff;
  color: #61718d;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  font-weight: 600;
}

.tab.active {
  background: #176bff;
  color: #ffffff;
}

.rank {
  width: 72rpx;
  color: #176bff;
  font-weight: 800;
}

.rank-user {
  flex: 1;
  min-width: 0;
  gap: 18rpx;
  align-items: center;
}

.small-avatar {
  width: 64rpx;
  height: 64rpx;
  flex: 0 0 auto;
}

.avatar {
  border-radius: 999rpx;
  overflow: hidden;
  border: 1rpx solid #e0e6f0;
  background: #fff;
}

.avatar-image {
  width: 100%;
  height: 100%;
  display: block;
}

.rank-meta {
  min-width: 0;
  flex: 1;
}

.rank-meta .title {
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.rank-score {
  flex: 0 0 auto;
}
