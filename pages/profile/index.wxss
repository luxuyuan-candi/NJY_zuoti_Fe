.profile-card {
  display: flex;
  align-items: center;
  gap: 22rpx;
}

.avatar {
  width: 96rpx;
  height: 96rpx;
  border-radius: 999rpx;
  overflow: hidden;
  border: 1rpx solid #e0e6f0;
  background: #fff;
}

.avatar-image {
  display: block;
  width: 100%;
  height: 100%;
}

.medal {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 12rpx;
  min-height: 132rpx;
  text-align: center;
  font-size: 24rpx;
}
