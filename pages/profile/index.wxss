.profile-card {
  display: flex;
  align-items: center;
  gap: 22rpx;
  padding-top: 34rpx;
  padding-bottom: 34rpx;
}

.avatar-shell {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 132rpx;
  height: 132rpx;
  border-radius: 999rpx;
  background: linear-gradient(180deg, rgba(255, 249, 238, 1) 0%, rgba(246, 236, 218, 1) 100%);
  box-shadow: inset 0 0 0 1rpx rgba(197, 161, 93, 0.25);
}

.avatar {
  width: 108rpx;
  height: 108rpx;
  border-radius: 999rpx;
  overflow: hidden;
  border: 3rpx solid rgba(192, 153, 82, 0.4);
  background: #fffaf4;
}

.avatar-image {
  display: block;
  width: 100%;
  height: 100%;
}

.profile-info {
  flex: 1;
  min-width: 0;
}

.name-row {
  display: flex;
  align-items: center;
  flex-wrap: wrap;
  gap: 14rpx;
}

.name-row .title {
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.role-tag {
  flex: 0 0 auto;
  padding: 10rpx 18rpx;
  border-radius: 999rpx;
  background: rgba(195, 154, 83, 0.14);
  color: #a77734;
  font-size: 22rpx;
  line-height: 1;
}

.profile-quote {
  display: block;
  margin-top: 12rpx;
  color: #7b6d57;
  font-size: 24rpx;
}

.medal {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 12rpx;
  min-height: 144rpx;
  text-align: center;
  font-size: 24rpx;
}

.tool-card {
  padding-top: 24rpx;
  padding-bottom: 24rpx;
}

.tool-main {
  gap: 16rpx;
}

.tool-icon-shell {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 76rpx;
  height: 76rpx;
  border-radius: 22rpx;
  background: linear-gradient(180deg, rgba(37, 78, 55, 0.1) 0%, rgba(195, 154, 83, 0.1) 100%);
}

.tool-icon {
  width: 40rpx;
  height: 40rpx;
}
