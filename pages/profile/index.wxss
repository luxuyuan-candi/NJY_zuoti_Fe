.profile-card {
  display: flex;
  align-items: center;
  gap: 22rpx;
}

.avatar {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 96rpx;
  height: 96rpx;
  border-radius: 999rpx;
  background: #176bff;
  color: #fff;
  font-size: 38rpx;
  font-weight: 800;
}

.login-btn {
  width: 132rpx;
  height: 64rpx;
  font-size: 24rpx;
}

.medal {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 12rpx;
  min-height: 132rpx;
  text-align: center;
  font-size: 24rpx;
}
