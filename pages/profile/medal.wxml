<view class="page">
  <view class="hero">
    <text class="hero-title">我的奖牌</text>
    <text class="hero-subtitle">记录学习里程碑和练习成就。</text>
  </view>
  <view class="section list">
    <view class="card row" wx:for="{{medals}}" wx:key="name">
      <text class="medal-icon">🏅</text>
      <view>
        <view class="row" style="gap: 12rpx; align-items: center;">
          <text class="title">{{item.name}}</text>
          <text class="tag {{item.achieved ? '' : 'gray'}}">{{item.achieved ? '已获得' : '未获得'}}</text>
        </view>
        <text class="desc">{{item.desc}}</text>
      </view>
    </view>
    <view class="card" wx:if="{{!medals.length}}">
      <text class="title">暂无奖牌</text>
      <text class="desc">完成练习和积累操作后，这里会展示你的奖牌进度。</text>
    </view>
  </view>
</view>
