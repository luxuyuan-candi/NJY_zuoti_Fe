<view class="page">
  <view class="tabs">
    <view wx:for="{{filters}}" wx:key="*this" class="tab {{index === 0 ? 'active' : ''}}">{{item}}</view>
  </view>

  <view class="section list">
    <view class="card" wx:for="{{papers}}" wx:key="id" data-id="{{item.id}}" bindtap="goIntro">
      <view class="row between">
        <text class="title">{{item.name}}</text>
        <text class="tag gray">{{item.minutes}} 分钟</text>
      </view>
      <text class="desc">{{item.total}} 题，已完成 {{item.count}} 次，最高分 {{item.best || '暂无'}}</text>
    </view>
  </view>
</view>
