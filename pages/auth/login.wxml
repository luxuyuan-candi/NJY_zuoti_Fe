<view class="page">
  <view class="hero">
    <text class="hero-title">身份配置</text>
    <text class="hero-subtitle">系统已通过微信 openid 识别你的身份，可补充头像、昵称和邮箱。</text>
  </view>

  <view class="section card profile-form">
    <view class="avatar-large">
      <image wx:if="{{avatarUrl}}" class="avatar-image" src="{{avatarUrl}}" mode="aspectFill"></image>
    </view>

    <view class="avatar-actions">
      <view class="btn secondary avatar-trigger" bindtap="chooseAvatarAction">头像训责</view>
    </view>

    <text class="field-label">昵称</text>
    <input class="input" value="{{nickname}}" maxlength="128" placeholder="填写昵称" bindinput="onNicknameInput" />

    <text class="field-label">邮箱</text>
    <input class="input" value="{{email}}" maxlength="255" type="text" placeholder="填写邮箱" bindinput="onEmailInput" />

    <view class="btn save-btn" bindtap="saveProfile">{{saving ? '保存中' : '保存资料'}}</view>
  </view>
</view>
