.profile-form {
  display: flex;
  flex-direction: column;
  align-items: stretch;
}

.avatar-large {
  align-self: center;
  width: 156rpx;
  height: 156rpx;
  overflow: hidden;
  border: 1rpx solid #dfe6f2;
  border-radius: 999rpx;
  background: #fff;
}

.avatar-image {
  display: block;
  width: 100%;
  height: 100%;
}

.avatar-actions {
  margin-top: 28rpx;
}

.avatar-trigger {
  width: 100%;
}

.field-label {
  margin: 28rpx 0 12rpx;
  color: #253149;
  font-size: 24rpx;
  font-weight: 700;
}

.save-btn {
  margin-top: 34rpx;
}

.picker-mask {
  position: fixed;
  inset: 0;
  z-index: 30;
  display: flex;
  align-items: flex-end;
  background: rgba(23, 32, 51, 0.28);
}

.picker-sheet {
  width: 100%;
  padding: 24rpx 28rpx 34rpx;
  border-top-left-radius: 24rpx;
  border-top-right-radius: 24rpx;
  background: #fff;
  box-sizing: border-box;
}

.picker-title {
  display: block;
  margin-bottom: 18rpx;
  text-align: center;
  font-size: 28rpx;
  font-weight: 700;
  color: #172033;
}

.picker-btn {
  width: 100%;
  margin-top: 14rpx;
}

.native-picker-btn {
  padding: 0;
  line-height: 88rpx;
}

.native-picker-btn::after {
  border: 0;
}
