.profile-form {
  display: flex;
  flex-direction: column;
  align-items: stretch;
}

.avatar-large {
  align-self: center;
  width: 156rpx;
  height: 156rpx;
  overflow: hidden;
  border: 1rpx solid #dfe6f2;
  border-radius: 999rpx;
  background: #fff;
}

.avatar-image {
  display: block;
  width: 100%;
  height: 100%;
}

.openid {
  margin-top: 18rpx;
  text-align: center;
  color: #7d8798;
  font-size: 22rpx;
  word-break: break-all;
}

.avatar-actions {
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  gap: 14rpx;
  margin-top: 28rpx;
}

.small-btn {
  height: 72rpx;
  border-radius: 12rpx;
  font-size: 24rpx;
}

.native-btn {
  margin: 0;
  padding: 0;
  line-height: normal;
}

.native-btn::after {
  border: 0;
}

.field-label {
  margin: 28rpx 0 12rpx;
  color: #253149;
  font-size: 24rpx;
  font-weight: 700;
}

.save-btn {
  margin-top: 34rpx;
}
