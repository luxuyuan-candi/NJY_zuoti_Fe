.profile-form {
  display: flex;
  flex-direction: column;
  align-items: stretch;
}

.avatar-large {
  align-self: center;
  width: 156rpx;
  height: 156rpx;
  overflow: hidden;
  border: 1rpx solid #dfe6f2;
  border-radius: 999rpx;
  background: #fff;
}

.avatar-image {
  display: block;
  width: 100%;
  height: 100%;
}

.avatar-actions {
  margin-top: 28rpx;
}

.avatar-trigger {
  width: 100%;
}

.native-avatar-btn {
  padding: 0;
  line-height: 88rpx;
}

.native-avatar-btn::after {
  border: 0;
}

.field-label {
  margin: 28rpx 0 12rpx;
  color: #253149;
  font-size: 24rpx;
  font-weight: 700;
}

.save-btn {
  margin-top: 34rpx;
}
