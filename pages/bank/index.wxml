<view class="page">
  <block wx:if="{{authorized}}">
  <input class="input" placeholder="搜索题库或等级" bindinput="updateKeyword" />

  <view class="section tabs">
    <view wx:for="{{tabs}}" wx:key="*this" data-tab="{{item}}" bindtap="switchTab" class="tab {{activeTab === item ? 'active' : ''}}">{{item}}</view>
  </view>
  </block>

  <view wx:if="{{loading}}" class="empty card">
    <text>正在加载题库...</text>
  </view>

  <view wx:elif="{{!authorized}}" class="empty card">
    <text>{{unauthorizedMessage}}</text>
  </view>

  <view wx:elif="{{!visibleBanks.length}}" class="empty card">
    <text>没有符合条件的题库。</text>
  </view>

  <view wx:else class="section list">
    <view class="card" wx:for="{{visibleBanks}}" wx:key="id" data-id="{{item.id}}" bindtap="goChapter">
      <view class="row between">
        <text class="tag">{{item.levelLabel}}</text>
        <text class="muted">{{item.cached}}</text>
      </view>
      <text class="title" style="margin-top: 18rpx; display: block;">{{item.name}}</text>
      <text class="desc">{{item.desc}}</text>
      <view class="row between" style="margin-top: 22rpx;">
        <text class="muted">题目 {{item.total}}</text>
        <text class="muted">{{item.type}}</text>
      </view>
      <view class="progress" style="margin-top: 14rpx;">
        <view class="progress-fill" style="width: 100%;"></view>
      </view>
    </view>
  </view>
</view>
