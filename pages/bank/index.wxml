<view class="page">
  <view class="hero bank-hero">
    <text class="hero-title">Question Bank</text>
    <text class="hero-subtitle">Practice by bank and level with a cleaner study flow.</text>
  </view>

  <block wx:if="{{authorized}}">
    <view class="section">
      <input class="input bank-search" placeholder="Search bank or level" bindinput="updateKeyword" />
    </view>
  </block>

  <view wx:if="{{loading}}" class="section empty card">
    <text>Loading banks...</text>
  </view>

  <view wx:elif="{{!authorized}}" class="section empty card">
    <text>{{unauthorizedMessage}}</text>
  </view>

  <view wx:elif="{{!visibleBanks.length}}" class="section empty card">
    <text>No matching banks.</text>
  </view>

  <view wx:else class="section list">
    <view class="card bank-card" wx:for="{{visibleBanks}}" wx:key="id" data-id="{{item.id}}" bindtap="goChapter">
      <view class="row between bank-card-head">
        <text class="tag">{{item.levelLabel}}</text>
        <text class="muted">{{item.type}}</text>
      </view>
      <text class="title bank-card-title">{{item.name}}</text>
      <text class="desc bank-card-desc">{{item.desc}}</text>
      <view class="row between bank-card-meta">
        <text class="muted">Questions {{item.total}}</text>
        <text class="muted">{{item.cached}}</text>
      </view>
      <view class="progress bank-card-progress">
        <view class="progress-fill" style="width: 100%;"></view>
      </view>
    </view>
  </view>
</view>
