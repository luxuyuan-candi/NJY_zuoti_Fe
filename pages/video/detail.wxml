<view class="page">
  <video
    class="video-panel"
    src="{{video.url}}"
    poster="{{video.coverUrl}}"
    controls
    show-center-play-btn
    object-fit="contain"
  ></video>
  <view class="section card">
    <text class="title">{{video.title}}</text>
    <text class="desc">介绍题库授权、章节练习、模拟考试、错题复盘和离线缓存能力。</text>
  </view>
</view>
