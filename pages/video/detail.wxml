<view class="page">
  <video
    class="video-panel"
    src="{{video.url}}"
    poster="{{video.coverUrl}}"
    controls
    show-center-play-btn
    object-fit="contain"
  ></video>
  <view class="section card">
    <text class="title">{{video.title}}</text>
    <text class="desc">{{video.desc || '首页教学视频。'}}</text>
  </view>
</view>
