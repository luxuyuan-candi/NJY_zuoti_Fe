<view class="page {{recordMode ? '' : 'with-bottom-bar'}}">
  <view class="hero">
    <text class="hero-title">{{title}}</text>
    <text class="hero-subtitle">{{subtitle}}</text>
  </view>

  <view class="section list">
    <view class="card" wx:for="{{mistakes}}" wx:key="id" data-id="{{item.id}}" bindtap="openDetail">
      <view class="row between">
        <text class="title">{{item.title}}</text>
        <text class="tag gray">{{recordMode ? '本次错题' : ('做错 ' + item.wrongTimes + ' 次')}}</text>
      </view>
      <text class="desc">{{item.chapter}}</text>
      <view wx:if="{{item.selectedAnswer || item.correctAnswer}}" class="desc" style="margin-top: 12rpx;">你的答案：{{item.selectedAnswer || '未作答'}} / 正确答案：{{item.correctAnswer || '-'}}</view>
      <view wx:if="{{item.analysis}}" class="desc" style="margin-top: 12rpx;">解析：{{item.analysis}}</view>
      <view wx:if="{{!recordMode}}" class="btn secondary" style="margin-top: 18rpx; height: 64rpx;" data-id="{{item.id}}" catchtap="remove">移出错题本</view>
    </view>
    <view class="card" wx:if="{{!mistakes.length}}">
      <text class="title">暂无错题</text>
      <text class="desc">{{recordMode ? '本次完成记录没有错题。' : '完成练习后答错的题目会进入这里，并累计做错次数。'}}</text>
    </view>
  </view>

  <view wx:if="{{!recordMode}}" class="bottom-bar">
    <view class="btn" bindtap="practice">开始错题重做</view>
  </view>
</view>
