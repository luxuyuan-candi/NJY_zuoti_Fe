<view class="page {{recordMode ? '' : 'with-bottom-bar'}}">
  <view class="hero">
    <text class="hero-title">{{title}}</text>
    <text class="hero-subtitle">{{subtitle}}</text>
    <view wx:if="{{!recordMode && !loading && mistakes.length}}" class="hero-action" bindtap="removeAll">清空错题</view>
  </view>

  <view class="section list">
    <view class="card" wx:if="{{loading}}">
      <text class="title">正在加载</text>
      <text class="desc">{{recordMode ? '正在加载本次错题...' : '正在加载错题本...'}}</text>
    </view>
    <block wx:else>
      <view class="card mistake-card" wx:for="{{mistakes}}" wx:key="id" data-id="{{item.id}}" bindtap="openDetail">
        <view class="row between">
          <text class="title">{{item.title}}</text>
          <text class="tag gray">{{recordMode ? '本次错题' : ('做错 ' + item.wrongTimes + ' 次')}}</text>
        </view>
        <text class="desc">{{item.chapter}}</text>
        <view wx:if="{{item.selectedAnswer || item.correctAnswer}}" class="mistake-meta">你的答案：{{item.selectedAnswer || '-'}} / 正确答案：{{item.correctAnswer || '-'}}</view>
        <view wx:if="{{item.analysis}}" class="mistake-analysis">{{item.analysis}}</view>
        <view wx:if="{{!recordMode}}" class="btn secondary mini-action" data-id="{{item.id}}" catchtap="remove">移出错题本</view>
      </view>
      <view class="card empty-state-card" wx:if="{{!mistakes.length}}">
        <text class="title">暂无错题</text>
        <text class="desc">{{recordMode ? '本次记录没有错题。' : '练习后答错的题目会出现在这里。'}}</text>
      </view>
    </block>
  </view>

  <view wx:if="{{!recordMode}}" class="bottom-bar">
    <view class="btn" bindtap="practice">开始错题重做</view>
  </view>
</view>
