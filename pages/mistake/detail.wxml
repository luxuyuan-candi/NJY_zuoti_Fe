<view class="page">
  <view class="hero">
    <text class="hero-title">{{title || '错题详情'}}</text>
    <text class="hero-subtitle">{{subtitle}}</text>
  </view>

  <view wx:if="{{loading}}" class="section card">
    <text class="desc">正在加载题目详情...</text>
  </view>

  <block wx:elif="{{question}}">
    <view class="section card">
      <view class="row between">
        <text class="tag">{{question.typeLabel || '题目'}}</text>
        <text class="tag gray">{{mode === 'record' ? '本次错题' : ('做错 ' + question.wrongTimes + ' 次')}}</text>
      </view>
      <text class="title" style="margin-top: 20rpx;">{{question.stem}}</text>

      <view wx:if="{{question.options && question.options.length}}" class="option-list">
        <view
          wx:for="{{question.options}}"
          wx:key="key"
          class="option {{mode === 'record' && question.selectedAnswer === item.key ? 'selected' : ''}} {{question.correctAnswer === item.key ? 'right' : ''}}"
        >
          <text class="option-key">{{item.key}}</text>
          <text class="option-text">{{item.text}}</text>
        </view>
      </view>
      <view wx:else class="analysis practical-detail">
        <text class="desc">本题为简答题。</text>
      </view>
    </view>

    <view class="section card analysis">
      <text class="title">作答信息</text>
      <text wx:if="{{mode === 'record'}}" class="desc">你的答案：{{question.selectedAnswer || '未作答'}}</text>
      <text class="desc">正确答案：{{question.correctAnswer || '-'}}</text>
      <text class="desc">答案解析：{{question.analysis || '当前题目暂无解析。'}}</text>
    </view>
  </block>
</view>
