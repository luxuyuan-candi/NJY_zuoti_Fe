.user-card {
  display: flex;
  align-items: center;
  gap: 18rpx;
}

.avatar {
  width: 76rpx;
  height: 76rpx;
  border: 1rpx solid #e0e6f0;
  border-radius: 999rpx;
  overflow: hidden;
  background: #fff;
}

.avatar-image {
  display: block;
  width: 100%;
  height: 100%;
}

.user-info {
  flex: 1;
  min-width: 0;
}

.name-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.name-row .title {
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.role-tag {
  flex: 0 0 auto;
  padding: 8rpx 14rpx;
  border-radius: 999rpx;
  background: #eef5ff;
  color: #176bff;
  font-size: 22rpx;
  line-height: 1;
}

.small-btn {
  width: 108rpx;
  height: 58rpx;
  padding: 0;
  font-size: 24rpx;
}
