<view class="page">
  <view class="hero">
    <text class="hero-title">查看反馈</text>
    <text class="hero-subtitle">查看用户提交的最新反馈内容</text>
  </view>

  <view class="section">
    <view class="section-head">
      <text class="section-title">反馈列表</text>
      <text class="section-link" bindtap="loadFeedback">刷新</text>
    </view>

    <view wx:if="{{loading}}" class="empty">正在加载</view>
    <view wx:elif="{{!items.length}}" class="empty">暂无反馈</view>
    <view wx:else class="list">
      <view class="card feedback-card" wx:for="{{items}}" wx:key="id">
        <view class="feedback-head">
          <text class="title">{{item.displayName}}</text>
          <text class="time">{{item.createdAt}}</text>
        </view>
        <text class="status-tag">{{item.statusLabel || item.status}}</text>
        <text class="feedback-content">{{item.content}}</text>
      </view>
    </view>
  </view>
</view>
