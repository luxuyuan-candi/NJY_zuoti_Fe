.feedback-card {
  gap: 16rpx;
}

.feedback-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
}

.time {
  flex: 0 0 auto;
  color: #8a94a7;
  font-size: 22rpx;
}

.status-tag {
  display: inline-flex;
  width: fit-content;
  padding: 8rpx 14rpx;
  border-radius: 999rpx;
  background: #fff3d8;
  color: #a66b00;
  font-size: 22rpx;
  line-height: 1;
}

.feedback-content {
  color: #52627d;
  font-size: 26rpx;
  line-height: 1.7;
  word-break: break-all;
}
