<view class="page">
  <view class="hero">
    <text class="hero-title">公告配置</text>
    <text class="hero-subtitle">首页滚动公告和公告详情共用这份内容。</text>
  </view>

  <view wx:if="{{loading}}" class="section card">
    <text class="desc">正在加载公告配置...</text>
  </view>

  <view wx:else class="section list">
    <view class="card">
      <text class="section-title">公告标题</text>
      <input class="field-input" placeholder="请输入公告标题" value="{{title}}" bindinput="onTitleInput" maxlength="60" />
    </view>

    <view class="card">
      <text class="section-title">公告内容</text>
      <textarea
        class="field-textarea"
        placeholder="请输入公告内容"
        value="{{content}}"
        bindinput="onContentInput"
        maxlength="500"
      ></textarea>
    </view>

    <view class="btn" bindtap="save">{{saving ? '保存中...' : '保存公告'}}</view>
  </view>
</view>
