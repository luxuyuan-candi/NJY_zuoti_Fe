.section-head {
  display: flex;
  align-items: baseline;
  justify-content: space-between;
  gap: 16rpx;
}

.section-meta {
  font-size: 24rpx;
  color: #7c8aa5;
}

.trend-canvas {
  width: 100%;
  height: 440rpx;
  margin-top: 28rpx;
}

.legend {
  display: flex;
  align-items: center;
  gap: 28rpx;
  margin-top: 24rpx;
}

.legend-item {
  display: flex;
  align-items: center;
  gap: 10rpx;
}

.legend-swatch {
  width: 28rpx;
  height: 12rpx;
  border-radius: 999rpx;
}

.bar-swatch {
  background: linear-gradient(180deg, rgba(25, 167, 206, 0.85) 0%, rgba(23, 107, 255, 0.5) 100%);
}

.line-swatch {
  background: #176bff;
}

.legend-text {
  font-size: 24rpx;
  color: #52627d;
}
