<view class="page with-bottom-bar">
  <view class="hero">
    <text class="hero-title">练习设置</text>
    <text class="hero-subtitle">{{title || bankName || '当前题库'}}，共 {{totalQuestions}} 题，本次预计 {{selectedCount}} 题。</text>
  </view>

  <view class="section">
    <view class="section-head"><text class="section-title">题目数量</text></view>
    <view class="card picker-card">
      <picker mode="selector" range="{{countOptions}}" value="{{selectedCountIndex}}" bindchange="changeCount">
        <view class="picker-trigger row between">
          <text class="title">选择题数</text>
          <text class="picker-value">{{selectedCount}} 题</text>
        </view>
      </picker>
    </view>
  </view>

  <view class="section list">
    <view class="card row between">
      <text class="title">出题顺序</text>
      <text class="tag">{{order}}</text>
    </view>
    <view class="card row between">
      <text class="title">答后显示解析</text>
      <switch checked="{{showAnalysis}}" bindchange="toggleAnalysis" />
    </view>
  </view>

  <view class="bottom-bar">
    <view class="btn" bindtap="start">开始练习</view>
  </view>
</view>
