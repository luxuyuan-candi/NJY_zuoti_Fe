.answer-top {
  margin-bottom: 24rpx;
}

.option-list {
  display: flex;
  flex-direction: column;
  gap: 18rpx;
  margin-top: 26rpx;
}

.option {
  display: flex;
  gap: 18rpx;
  padding: 22rpx;
  border: 1rpx solid #e7eaf0;
  border-radius: 14rpx;
}

.option.selected {
  border-color: #176bff;
  background: #eef5ff;
}

.option.right {
  border-color: #18a058;
  background: #edf8f1;
}

.option-key {
  font-weight: 800;
}

.option-text {
  flex: 1;
  line-height: 1.5;
}

.analysis {
  border-color: #bfe5cd;
}

.practical-content {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
  margin-top: 26rpx;
}

.practical-block {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.practical-label {
  color: #176bff;
  font-size: 26rpx;
  font-weight: 700;
}

.score-table {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.score-row {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
  padding: 16rpx;
  border-radius: 12rpx;
  background: #f7f8fb;
}

.score-cell {
  color: #52627d;
  font-size: 24rpx;
  line-height: 1.6;
}

.small-btn {
  min-width: 160rpx;
  height: 64rpx;
  padding: 0 24rpx;
  font-size: 26rpx;
}

.number-grid {
  display: grid;
  grid-template-columns: repeat(5, 1fr);
  gap: 16rpx;
  margin-top: 20rpx;
}

.navigator-mask {
  position: fixed;
  inset: 0;
  background: rgba(15, 23, 42, 0.28);
  z-index: 18;
}

.navigator-sheet {
  position: fixed;
  right: 24rpx;
  bottom: calc(env(safe-area-inset-bottom) + 132rpx);
  left: 24rpx;
  max-height: 46vh;
  padding: 28rpx 24rpx;
  border-radius: 18rpx;
  background: #ffffff;
  box-shadow: 0 18rpx 48rpx rgba(15, 23, 42, 0.18);
  overflow-y: auto;
  z-index: 19;
}

.navigator-head {
  margin-bottom: 8rpx;
}

.number {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 64rpx;
  border-radius: 12rpx;
  background: #f0f2f5;
  color: #1f2937;
}

.number.done {
  background: #18a058;
  color: #fff;
}

.number.doubtful {
  background: #f4b740;
  color: #fff;
}

.number.active {
  background: #176bff;
  color: #fff;
}
