.answer-top {
  margin-bottom: 24rpx;
}

.option-list {
  display: flex;
  flex-direction: column;
  gap: 22rpx;
  margin-top: 28rpx;
}

.option {
  display: flex;
  align-items: center;
  gap: 22rpx;
  padding: 28rpx 24rpx;
  border: 1rpx solid rgba(196, 176, 146, 0.26);
  border-radius: 24rpx;
  background: rgba(255, 253, 248, 0.88);
  box-shadow: 0 10rpx 28rpx rgba(74, 56, 31, 0.05);
}

.option.selected {
  border-color: rgba(191, 145, 68, 0.42);
  background: rgba(255, 249, 239, 0.98);
  box-shadow: 0 14rpx 30rpx rgba(191, 145, 68, 0.1);
}

.option.right {
  border-color: rgba(38, 84, 59, 0.34);
  background: rgba(244, 250, 245, 0.96);
}

.option-key {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 62rpx;
  height: 62rpx;
  flex: 0 0 auto;
  border-radius: 999rpx;
  background: #224a34;
  color: #fffaf2;
  font-size: 34rpx;
  font-weight: 800;
}

.option-text {
  flex: 1;
  color: #233829;
  line-height: 1.7;
}

.analysis {
  border-color: rgba(38, 84, 59, 0.18);
}

.practical-content {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
  margin-top: 26rpx;
}

.practical-block {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.practical-label {
  color: #29553c;
  font-size: 26rpx;
  font-weight: 700;
}

.practical-answer-input {
  width: 100%;
  min-height: 280rpx;
  padding: 24rpx;
  border: 1rpx solid rgba(196, 176, 146, 0.26);
  border-radius: 24rpx;
  background: rgba(255, 251, 246, 0.92);
  box-sizing: border-box;
  line-height: 1.7;
}

.reference-answer {
  white-space: pre-wrap;
}

.score-table {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.score-row {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
  padding: 16rpx;
  border-radius: 18rpx;
  background: rgba(255, 250, 242, 0.9);
}

.score-cell {
  color: #6d6458;
  font-size: 24rpx;
  line-height: 1.6;
}

.small-btn {
  min-width: 160rpx;
  height: 66rpx;
  padding: 0 24rpx;
  font-size: 24rpx;
}

.number-grid {
  display: grid;
  grid-template-columns: repeat(5, 1fr);
  gap: 16rpx;
  margin-top: 20rpx;
}

.navigator-mask {
  position: fixed;
  inset: 0;
  z-index: 18;
  background: rgba(16, 22, 16, 0.22);
}

.navigator-sheet {
  position: fixed;
  right: 24rpx;
  bottom: calc(env(safe-area-inset-bottom) + 132rpx);
  left: 24rpx;
  z-index: 19;
  max-height: 46vh;
  padding: 30rpx 24rpx;
  border: 1rpx solid rgba(196, 176, 146, 0.3);
  border-radius: 28rpx;
  background: rgba(255, 251, 246, 0.98);
  box-shadow: 0 18rpx 48rpx rgba(54, 42, 25, 0.14);
  overflow-y: auto;
}

.navigator-head {
  margin-bottom: 8rpx;
}

.number {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 70rpx;
  border: 1rpx solid rgba(198, 179, 149, 0.24);
  border-radius: 18rpx;
  background: rgba(255, 249, 240, 0.92);
  color: #2b392d;
}

.number.done {
  border-color: #28553c;
  background: #28553c;
  color: #fff9ef;
}

.number.doubtful {
  border-color: #c49753;
  background: #c49753;
  color: #fffaf3;
}

.number.active {
  border-color: #1e4a34;
  background: #1e4a34;
  color: #fff9ef;
}
