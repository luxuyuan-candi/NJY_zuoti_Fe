<view class="page with-bottom-bar">
  <view wx:if="{{currentQuestion}}" class="answer-top card">
    <view class="row between">
      <text class="tag">{{currentQuestion.typeLabel}}</text>
      <text class="muted">{{currentQuestion.no}} / {{currentQuestion.total}}</text>
    </view>
    <view class="progress" style="margin-top: 18rpx;">
      <view class="progress-fill" style="width: {{currentQuestion.no / currentQuestion.total * 100}}%;"></view>
    </view>
  </view>

  <view wx:if="{{currentQuestion}}" class="section card">
    <text class="title">{{currentQuestion.stem}}</text>
    <view wx:if="{{currentQuestion.options && currentQuestion.options.length}}" class="option-list">
      <view wx:for="{{currentQuestion.options}}" wx:key="key" data-key="{{item.key}}" bindtap="selectOption" class="option {{selected === item.key ? 'selected' : ''}} {{submitted && analysisRevealed && item.key === currentQuestion.answer ? 'right' : ''}}">
        <text class="option-key">{{item.key}}</text>
        <text class="option-text">{{item.text}}</text>
      </view>
    </view>
    <view wx:else class="practical-content">
      <view wx:if="{{currentQuestion.content.preparation}}" class="practical-block">
        <text class="practical-label">考评准备</text>
        <text class="desc">{{currentQuestion.content.preparation}}</text>
      </view>
      <view wx:if="{{currentQuestion.content.steps}}" class="practical-block">
        <text class="practical-label">考评步骤</text>
        <text class="desc">{{currentQuestion.content.steps}}</text>
      </view>
      <view wx:if="{{currentQuestion.content.notes}}" class="practical-block">
        <text class="practical-label">注意事项</text>
        <text class="desc">{{currentQuestion.content.notes}}</text>
      </view>
      <view wx:if="{{currentQuestion.content.keyPoints}}" class="practical-block">
        <text class="practical-label">考核要点</text>
        <text class="desc">{{currentQuestion.content.keyPoints}}</text>
      </view>
      <view wx:if="{{currentQuestion.content.scoringTitle}}" class="practical-block">
        <text class="practical-label">{{currentQuestion.content.scoringTitle}}</text>
        <view class="score-table">
          <view wx:for="{{currentQuestion.content.scoringRows}}" wx:key="index" class="score-row">
            <text class="score-cell" wx:for="{{item}}" wx:key="subIndex">{{item}}</text>
          </view>
        </view>
      </view>
    </view>
  </view>

  <view wx:if="{{submitted && !showAnalysis && !analysisRevealed}}" class="section card analysis">
    <view class="row between">
      <text class="desc">已提交本题答案。</text>
      <view class="btn secondary small-btn" bindtap="revealAnalysis">查看解析</view>
    </view>
  </view>

  <view wx:if="{{submitted && analysisRevealed}}" class="section card analysis">
    <text class="title">答案解析</text>
    <text wx:if="{{currentQuestion.options && currentQuestion.options.length}}" class="desc">正确答案：{{currentQuestion.answer}}</text>
    <text wx:else class="desc">参考说明：本题为实操题，提交后按完成记录处理。</text>
    <text class="desc">{{currentQuestion.analysis || '当前题目暂无解析。'}}</text>
  </view>

  <view wx:if="{{showNavigator}}" class="section card">
    <text class="title">题目导航</text>
    <view class="number-grid">
      <text wx:for="{{navItems}}" wx:key="index" data-index="{{item.index}}" bindtap="openQuestion" class="number {{item.answered ? 'done' : ''}} {{item.doubtful ? 'doubtful' : ''}} {{currentIndex === item.index ? 'active' : ''}}">{{item.label}}</text>
    </view>
  </view>

  <view wx:if="{{!currentQuestion}}" class="section card">
    <text class="desc">正在加载题目...</text>
  </view>

  <view class="bottom-bar">
    <view class="btn ghost" bindtap="toggleNavigator">题号</view>
    <view class="btn ghost" bindtap="toggleDoubtful">{{doubtful ? '已存疑' : '存疑'}}</view>
    <view class="btn ghost" bindtap="toggleFavorite">{{favoriteId ? '已收藏' : '收藏'}}</view>
    <view wx:if="{{!submitted}}" class="btn" bindtap="submit">{{currentQuestion.options && currentQuestion.options.length ? '提交' : '完成本题'}}</view>
    <view wx:elif="{{allAnswered}}" class="btn" bindtap="finish">完成</view>
    <view wx:else class="btn" bindtap="nextQuestion">下一题</view>
  </view>
</view>
