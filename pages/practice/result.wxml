<view class="page">
  <view class="hero result-hero">
    <text class="hero-title">{{heroTitle}}</text>
    <text class="hero-subtitle">{{heroSubtitle}}</text>
  </view>

  <view class="section grid-3">
    <view class="card metric result-metric" wx:for="{{metrics}}" wx:key="label">
      <text class="metric-value">{{item.value}}</text>
      <text class="metric-label">{{item.label}}</text>
    </view>
  </view>

  <view wx:if="{{details.length}}" class="section list">
    <view class="card result-detail-card" wx:for="{{details}}" wx:key="name">
      <view class="row between">
        <text class="title">{{item.name}}</text>
        <text class="muted">{{item.accuracy}}%</text>
      </view>
      <view class="progress result-progress">
        <view class="progress-fill" style="width: {{item.accuracy}}%;"></view>
      </view>
    </view>
  </view>

  <view class="section grid-2">
    <view class="btn secondary" bindtap="goMistake">查看错题</view>
    <view class="btn" bindtap="retry">再练一次</view>
  </view>
</view>
